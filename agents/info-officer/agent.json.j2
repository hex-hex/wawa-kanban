{
  "id": {{ agent_id | tojson }},
  "name": {{ agent_display_name | tojson }},
  "workspace": {{ workspace_path | tojson }},
  "agentDir": {{ agent_dir_path | tojson }},
  "heartbeat": {
    "every": "1m",
    "target": "none"
  },
  "sandbox": {
    "mode": "off",
    "workspaceAccess": "rw",
    "browser": {
      "enabled": true,
      "headless": true
    }
  }
}
